---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const { title, description, ogImage = '/images/social-card.png', canonicalURL } = Astro.props;
const siteTitle = 'Londonberry';
const fullTitle = title === 'Home' ? `${siteTitle} | Build Faster. Think Bigger.` : `${title} | ${siteTitle}`;
const canonical = canonicalURL || new URL(Astro.url.pathname, Astro.site).href;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/services', label: 'Services', subtitle: 'What We Do' },
  { href: '/work', label: 'Work', subtitle: "What We've Built" },
  { href: '/about', label: 'About', subtitle: 'Who We Are' },
  { href: '/blog', label: 'Insights', subtitle: 'From The Blog' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteTitle} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/images/brand/logomark-color.svg" />
    <title>{fullTitle}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Londonberry",
      "description": "AI-powered custom software development, rapid prototyping, and strategic consulting for sports technology and startups.",
      "url": "https://londonberry.com",
      "logo": "https://londonberry.com/images/social-card.png",
      "email": "info@londonberry.com",
      "founder": {
        "@type": "Person",
        "name": "Ben McDonald"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Jacksonville",
        "addressRegion": "FL",
        "addressCountry": "US"
      },
      "areaServed": "Worldwide",
      "knowsAbout": [
        "Artificial Intelligence",
        "Custom Software Development",
        "Rapid Prototyping",
        "Sports Technology",
        "Product Management",
        "AI Strategy Consulting"
      ],
      "sameAs": [
        "https://github.com/Londonberry",
        "https://www.linkedin.com/company/londonberry"
      ]
    })} />
  </head>
  <body class="bg-white text-body font-sans antialiased">
    <header class="bg-primary overflow-visible relative z-10">
      <nav class="max-w-6xl mx-auto px-6 pt-5 pb-8 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/brand/logomark-white.svg" alt="" class="h-14 w-14" />
          <span class="text-white font-black text-3xl tracking-tight uppercase">Londonberry</span>
        </a>
        <div class="hidden lg:flex items-center gap-2">
          {navItems.map(item => {
            const isActive = currentPath === item.href;
            return (
            <a href={item.href} class={`nav-item relative text-white text-sm font-semibold uppercase tracking-wide${isActive ? ' active' : ''}`}>
              <span class="nav-label">{item.label}</span>
              <span class="nav-subtitle">{item.subtitle}</span>
              <svg class="nav-bubble-shape" viewBox="0 0 100 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4,6 L22,6 L30,0 L38,6 L96,6 Q100,6 100,10 L100,46 Q100,50 96,50 L78,50 L70,56 L62,50 L4,50 Q0,50 0,46 L0,10 Q0,6 4,6 Z" fill="rgba(255,255,255,0.18)"/>
              </svg>
            </a>
          );
          })}
          <a href="/contact" class="bg-white text-primary px-5 py-2 rounded-md text-sm font-bold uppercase tracking-wide hover:bg-white/90 transition-colors">Contact</a>
        </div>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden text-white" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden px-6 pb-4">
        <div class="flex flex-col gap-3">
          {navItems.map(item => (
            <a href={item.href} class={currentPath === item.href ? "text-white text-sm font-bold uppercase tracking-wide" : "text-white/90 hover:text-white text-sm font-semibold uppercase tracking-wide"}>{item.label}</a>
          ))}
          <a href="/contact" class="text-white font-bold text-sm uppercase tracking-wide">Contact</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-body text-white">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <img src="/images/brand/logomark-white.svg" alt="" class="h-9 w-9" />
              <span class="text-white font-extrabold text-xl tracking-tight uppercase">Londonberry</span>
            </div>
            <p class="text-white/70 text-sm leading-relaxed">AI-powered software development and strategy from Jacksonville, FL.</p>
          </div>
          <div>
            <h4 class="text-xs font-bold uppercase tracking-wider text-accent mb-4">Navigate</h4>
            <div class="flex flex-col gap-2">
              <a href="/services" class="text-white/70 hover:text-white text-sm transition-colors">Services</a>
              <a href="/work" class="text-white/70 hover:text-white text-sm transition-colors">Work</a>
              <a href="/about" class="text-white/70 hover:text-white text-sm transition-colors">About</a>
              <a href="/blog" class="text-white/70 hover:text-white text-sm transition-colors">Insights</a>
            </div>
          </div>
          <div>
            <h4 class="text-xs font-bold uppercase tracking-wider text-accent mb-4">Get In Touch</h4>
            <a href="mailto:info@londonberry.com" class="text-white/70 hover:text-white text-sm transition-colors">info@londonberry.com</a>
            <div class="flex gap-4 mt-4">
              <a href="https://github.com/Londonberry" class="text-white/70 hover:text-white transition-colors" aria-label="GitHub">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="https://www.linkedin.com/company/londonberry" class="text-white/70 hover:text-white transition-colors" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
        <div class="border-t border-white/10 mt-8 pt-8 text-center">
          <p class="text-white/50 text-xs">&copy; {new Date().getFullYear()} Londonberry. All rights reserved. Jacksonville, FL.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>

    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "f0a5289d8a0b4c4fa63ecdd63fae70e0"}'></script>

    <!-- HubSpot Embed Code -->
    <script type="text/javascript" id="hs-script-loader" async defer src="//js-na2.hs-scripts.com/245928732.js"></script>
  </body>
</html>
