---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Londonberry about custom software development, AI consulting, or sports technology projects. Based in Jacksonville, FL."
>
  <!-- Header -->
  <section class="bg-primary text-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-xs font-bold uppercase tracking-widest text-white/60 mb-2">Let's Talk</h2>
      <h1 class="text-3xl md:text-5xl font-black leading-tight">Contact</h1>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-heading mb-6">
          Drop us a line.
        </h2>
        <p class="text-lg text-body/80 leading-relaxed mb-10">
          Whether you have a project in mind, want to explore how AI can help your business, or just want to talk sports tech — we'd love to hear from you.
        </p>

        <a
          href="mailto:info@londonberry.com"
          class="inline-flex items-center gap-3 bg-primary text-white px-10 py-4 rounded-md font-bold text-lg hover:bg-primary/90 transition-colors"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          info@londonberry.com
        </a>

        <div class="mt-16 pt-12 border-t border-muted/30">
          <div class="grid sm:grid-cols-3 gap-8 text-center">
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-heading/60 mb-2">Based In</h3>
              <p class="text-body/80">Jacksonville, FL</p>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-heading/60 mb-2">Working With</h3>
              <p class="text-body/80">Clients everywhere</p>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-heading/60 mb-2">Find Us</h3>
              <div class="flex justify-center gap-4">
                <a href="https://github.com/Londonberry" class="text-body/60 hover:text-primary transition-colors" aria-label="GitHub">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href="https://twitter.com/london_berry" class="text-body/60 hover:text-primary transition-colors" aria-label="Twitter">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
