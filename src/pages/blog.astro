---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Insights"
  description="Thoughts on AI-assisted development, sports technology, product strategy, and building software at startup speed from Londonberry founder Ben McDonald."
>
  <!-- Posts -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-6">
      {posts.map((post) => (
        <article class="border-b border-muted/30 py-10 first:pt-0 last:border-0">
          <time class="text-xs font-bold uppercase tracking-widest text-heading/60" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2 class="text-xl md:text-2xl font-bold text-heading mt-2 mb-3">
            <a href={`/blog/${post.id}`} class="hover:text-primary transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-body/70 leading-relaxed">{post.data.description}</p>
          <a href={`/blog/${post.id}`} class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">
            Read more &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
