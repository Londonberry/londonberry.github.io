---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Londonberry builds custom software at startup speed using AI-assisted development. Rapid prototyping, AI strategy consulting, and product management for sports tech and beyond."
>
  <!-- Hero -->
  <section class="bg-primary text-white">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-tight mb-6">
        Build faster.<br /><span class="text-white/50">Think bigger.</span>
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl leading-relaxed mb-8">
        AI-powered custom software development and strategy. We turn ideas into working products at startup speed — from rapid prototypes to production-ready platforms.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="bg-white text-primary px-8 py-3 rounded-md font-bold text-sm uppercase tracking-wide hover:bg-white/90 transition-colors text-center inline-flex items-center justify-center leading-none">
          Start a Conversation
        </a>
        <a href="/services" class="border-2 border-white text-white px-8 py-3 rounded-md font-bold text-sm uppercase tracking-wide hover:bg-white/10 transition-colors text-center inline-flex items-center justify-center leading-none">
          What We Do
        </a>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-xs font-bold uppercase tracking-widest text-heading/60 mb-2">How We Help</h2>
      <p class="text-2xl md:text-3xl font-bold text-heading mb-12 max-w-2xl">
        From first sketch to shipped product — we move fast and build smart.
      </p>
      <div class="grid md:grid-cols-3 gap-10">
        <!-- Rapid Prototyping -->
        <div class="group">
          <img src="/images/service_development.png" alt="" class="w-12 h-12 mb-5" />
          <h3 class="text-lg font-bold text-heading mb-3">Rapid Prototyping</h3>
          <p class="text-body/80 leading-relaxed">
            Go from idea to interactive prototype in days, not months. We use AI-assisted development to build, test, and iterate at a pace that keeps you ahead of the market.
          </p>
          <a href="/services#rapid-prototyping" class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">Learn more &rarr;</a>
        </div>
        <!-- AI Strategy -->
        <div class="group">
          <img src="/images/service_management.png" alt="" class="w-12 h-12 mb-5" />
          <h3 class="text-lg font-bold text-heading mb-3">AI Strategy & Consulting</h3>
          <p class="text-body/80 leading-relaxed">
            Not sure where AI fits in your business? We help you cut through the noise, identify real opportunities, and build an AI roadmap that actually delivers value.
          </p>
          <a href="/services#ai-strategy" class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">Learn more &rarr;</a>
        </div>
        <!-- Product Management -->
        <div class="group">
          <img src="/images/service_ui.png" alt="" class="w-12 h-12 mb-5" />
          <h3 class="text-lg font-bold text-heading mb-3">Product Management</h3>
          <p class="text-body/80 leading-relaxed">
            Strategic product thinking that connects your vision to what users actually need. We help define, prioritize, and ship the right features — not just more features.
          </p>
          <a href="/services#product-management" class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sports Tech Callout -->
  <section class="bg-heading text-white py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-xs font-bold uppercase tracking-widest text-accent mb-2">Our Sweet Spot</h2>
        <p class="text-2xl md:text-4xl font-bold leading-tight mb-6">
          We love building software for sports.
        </p>
        <p class="text-lg text-white/80 leading-relaxed mb-8">
          From travel ball organization platforms to video streaming ecosystems, we bring deep experience in sports technology. If your idea lives at the intersection of sports and software, we want to hear about it.
        </p>
        <a href="/work" class="bg-white text-heading px-8 py-3 rounded-md font-bold text-sm uppercase tracking-wide hover:bg-white/90 transition-colors inline-block">
          See Our Work
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">Ready to build something?</h2>
      <p class="text-lg text-body/70 mb-8 max-w-xl mx-auto">
        Whether you have a napkin sketch or a full product spec, we'll help you move fast.
      </p>
      <a href="/contact" class="bg-primary text-white px-8 py-3 rounded-md font-bold text-sm uppercase tracking-wide hover:bg-primary/90 transition-colors inline-block">
        Get In Touch
      </a>
    </div>
  </section>
</BaseLayout>
