---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = [...posts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { id: post.id },
    props: {
      post,
      related: sorted.filter((p) => p.id !== post.id).slice(0, 3),
    },
  }));
}

const { post, related } = Astro.props;
const { Content } = await render(post);

const canonicalURL = new URL(`/blog/${post.id}/`, Astro.site).href;
const ogImageRel = post.data.image ?? '/images/social-card.png';
const absoluteOgImage = new URL(ogImageRel, Astro.site).href;

const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": absoluteOgImage,
  "datePublished": post.data.date.toISOString(),
  "dateModified": (post.data.updated ?? post.data.date).toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "url": "https://londonberry.com/about/",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Londonberry",
    "logo": {
      "@type": "ImageObject",
      "url": "https://londonberry.com/images/social-card.png",
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL,
  },
  ...(post.data.tags && post.data.tags.length > 0 ? { "keywords": post.data.tags.join(', ') } : {}),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://londonberry.com/" },
    { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://londonberry.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalURL },
  ],
};

const graphLd = {
  "@context": "https://schema.org",
  "@graph": [blogPostingLd, breadcrumbLd],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImageRel}
  canonicalURL={canonicalURL}
  ogType="article"
  article={{
    publishedTime: post.data.date.toISOString(),
    modifiedTime: (post.data.updated ?? post.data.date).toISOString(),
    author: post.data.author,
    tags: post.data.tags,
    section: 'Insights',
  }}
  jsonLd={graphLd}
>
  <!-- Header -->
  <section class="bg-primary text-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <a href="/blog" class="text-white/60 text-sm font-semibold uppercase tracking-wide hover:text-white transition-colors">&larr; All Insights</a>
        <h1 class="text-2xl md:text-4xl font-black leading-tight mt-4">{post.data.title}</h1>
        <div class="mt-4 flex items-center gap-3 text-white/70 text-sm">
          <span>{post.data.author}</span>
          <span>&middot;</span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
          </time>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl blog-content text-lg">
        <Content />
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="border-t border-muted/30 py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-3xl">
          <h2 class="text-xs font-bold uppercase tracking-widest text-heading/60 mb-6">Keep reading</h2>
          <ul class="grid gap-6 md:grid-cols-3">
            {related.map((r) => (
              <li>
                <a href={`/blog/${r.id}`} class="block group">
                  <time class="text-xs font-semibold uppercase tracking-wider text-heading/60" datetime={r.data.date.toISOString()}>
                    {r.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}
                  </time>
                  <h3 class="text-base font-bold text-heading mt-2 group-hover:text-primary transition-colors">{r.data.title}</h3>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <!-- Back link -->
  <section class="pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <a href="/blog" class="text-primary font-semibold text-sm hover:underline">&larr; Back to all insights</a>
    </div>
  </section>
</BaseLayout>
